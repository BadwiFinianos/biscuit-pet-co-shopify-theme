{%- if section.settings.enabled and section.settings.text != blank -%}
  <div class="promobar">
    {%- if section.settings.link != blank -%}
      <a href="{{ section.settings.link }}">🎉 {{ section.settings.text }}</a>
    {%- else -%}
      <span>🎉 {{ section.settings.text }}</span>
    {%- endif -%}
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Promo Bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "Show promo bar",
      "default": false
    },
    {
      "type": "text",
      "id": "text",
      "label": "Promo text",
      "default": "Buy 3, get 30% off — automatically applied at checkout"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link (optional)"
    }
  ]
}
{% endschema %}
