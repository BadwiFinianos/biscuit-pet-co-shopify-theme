<section class="cats section wrap">
  <div class="section-head center" data-reveal>
    <span class="rule-orn"></span>
    <h2 class="section-title" style="margin-top:18px">{{ section.settings.heading }}</h2>
    <p class="section-sub">{{ section.settings.subheading }}</p>
  </div>
  <div class="grid grid-3">

    <a class="ctile navy" href="{{ section.settings.tile1_url | default: routes.collections_url | append: '/cat-litter' }}" data-reveal>
      <img class="mascot" src="{{ 'mascot-gold.png' | asset_url }}" alt="">
      <div class="ctile-body">
        <span class="eyebrow on-dark">{{ section.settings.tile1_eyebrow }}</span>
        <h3>{{ section.settings.tile1_title }}</h3>
        <p>{{ section.settings.tile1_desc }}</p>
        <span class="go">{{ section.settings.tile1_cta }} <span id="cat-arw1"></span></span>
      </div>
    </a>

    <a class="ctile cream" href="{{ section.settings.tile2_url | default: routes.collections_url | append: '/dog' }}" data-reveal data-delay="1">
      <img class="mascot" src="{{ 'mascot-navy.png' | asset_url }}" alt="">
      <div class="ctile-body">
        <span class="eyebrow">{{ section.settings.tile2_eyebrow }}</span>
        <h3>{{ section.settings.tile2_title }}</h3>
        <p>{{ section.settings.tile2_desc }}</p>
        <span class="go">{{ section.settings.tile2_cta }} <span id="cat-arw2"></span></span>
      </div>
    </a>

    <a class="ctile navy" href="{{ section.settings.tile3_url | default: routes.collections_url | append: '/accessories' }}" data-reveal data-delay="2">
      <img class="mascot" src="{{ 'mascot-gold.png' | asset_url }}" alt="">
      <div class="ctile-body">
        <span class="eyebrow on-dark">{{ section.settings.tile3_eyebrow }}</span>
        <h3>{{ section.settings.tile3_title }}</h3>
        <p>{{ section.settings.tile3_desc }}</p>
        <span class="go">{{ section.settings.tile3_cta }} <span id="cat-arw3"></span></span>
      </div>
    </a>

  </div>
</section>

<style>
.cats .grid{margin-top:48px}
.ctile{position:relative;border-radius:10px;overflow:hidden;min-height:340px;display:flex;align-items:flex-end;padding:32px;color:var(--cream);transition:transform .5s cubic-bezier(.2,.7,.2,1)}
.ctile:hover{transform:translateY(-6px)}
.ctile.navy{background:linear-gradient(180deg,#11114f,var(--navy))}
.ctile.cream{background:linear-gradient(180deg,#fff,var(--page-2));color:var(--navy)}
.ctile .mascot{position:absolute;right:-6%;top:-4%;height:70%;opacity:.9}
.ctile.cream .mascot{opacity:.85}
.ctile-body{position:relative;z-index:2}
.ctile h3{font-size:30px;letter-spacing:-.01em}
.ctile p{font-size:14px;margin-top:6px;opacity:.7;max-width:24ch}
.ctile .go{margin-top:18px;display:inline-flex;align-items:center;gap:8px;font-size:12px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;border-bottom:1.5px solid currentColor;padding-bottom:3px}
.ctile .go svg{width:16px;height:16px;transition:transform .3s}
.ctile:hover .go svg{transform:translateX(4px)}
@media(max-width:960px){.cats .grid-3{grid-template-columns:1fr}}
@media(max-width:560px){.ctile{min-height:260px}}
</style>

{% schema %}
{
  "name": "Shop by Companion",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Shop by companion"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Considered essentials for every member of the household."
    },
    { "type": "header", "content": "Tile 1 — Cats" },
    { "type": "text", "id": "tile1_eyebrow", "label": "Eyebrow", "default": "For Cats" },
    { "type": "text", "id": "tile1_title",   "label": "Title",   "default": "Litter & Cuisine" },
    { "type": "text", "id": "tile1_desc",    "label": "Description", "default": "Ultra-clumping litter and gently-cooked food." },
    { "type": "text", "id": "tile1_cta",     "label": "CTA text", "default": "Shop Cat" },
    { "type": "url",  "id": "tile1_url",     "label": "Link URL" },
    { "type": "header", "content": "Tile 2 — Dogs" },
    { "type": "text", "id": "tile2_eyebrow", "label": "Eyebrow", "default": "For Dogs" },
    { "type": "text", "id": "tile2_title",   "label": "Title",   "default": "Food & Chews" },
    { "type": "text", "id": "tile2_desc",    "label": "Description", "default": "Grain-free meals and slow-baked treats." },
    { "type": "text", "id": "tile2_cta",     "label": "CTA text", "default": "Shop Dog" },
    { "type": "url",  "id": "tile2_url",     "label": "Link URL" },
    { "type": "header", "content": "Tile 3 — Home" },
    { "type": "text", "id": "tile3_eyebrow", "label": "Eyebrow", "default": "For Home" },
    { "type": "text", "id": "tile3_title",   "label": "Title",   "default": "The Atelier" },
    { "type": "text", "id": "tile3_desc",    "label": "Description", "default": "Heirloom bowls and bouclé beds." },
    { "type": "text", "id": "tile3_cta",     "label": "CTA text", "default": "Shop Home" },
    { "type": "url",  "id": "tile3_url",     "label": "Link URL" }
  ],
  "presets": [{ "name": "Shop by Companion" }]
}
{% endschema %}
