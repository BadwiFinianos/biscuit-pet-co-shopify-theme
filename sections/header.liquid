<header class="site-header">
  <div class="header-row">
    <a class="brand" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        {{ section.settings.logo | image_url: height: 76 | image_tag: class: '', alt: shop.name }}
      {%- else -%}
        <img src="{{ 'wordmark-navy.png' | asset_url }}" alt="{{ shop.name }}" style="height:76px;width:auto" width="auto" height="76px">
      {%- endif -%}
    </a>

    <nav class="nav" aria-label="Primary">
      {%- for link in linklists[section.settings.menu].links -%}
        {%- if link.links.size > 0 -%}
          <div class="nav-item has-dropdown" data-nav-item>
            <button type="button" class="nav-trigger{% if link.active %} active{% endif %}" aria-expanded="false" aria-haspopup="true">
              {{ link.title }}
              <span class="nav-caret" aria-hidden="true"></span>
            </button>
            <div class="nav-dropdown">
              <div class="nav-dropdown-inner">
                {%- for child in link.links -%}
                  <div class="nav-col">
                    <a href="{{ child.url }}" class="nav-col-heading{% if child.active %} active{% endif %}">{{ child.title }}</a>
                    {%- if child.links.size > 0 -%}
                      <ul class="nav-col-list">
                        {%- for grandchild in child.links -%}
                          <li><a href="{{ grandchild.url }}"{% if grandchild.active %} class="active"{% endif %}>{{ grandchild.title }}</a></li>
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}
                  </div>
                {%- endfor -%}
              </div>
            </div>
          </div>
        {%- else -%}
          <a href="{{ link.url }}"{% if link.active %} class="active"{% endif %}>{{ link.title }}</a>
        {%- endif -%}
      {%- else -%}
        <a href="{{ routes.collections_url }}/all">Products</a>
        <a href="{{ routes.collections_url }}/cat-litter">Cat Litter</a>
        <a href="{{ routes.collections_url }}/food-treats">Food &amp; Treats</a>
        <a href="{{ routes.collections_url }}/dog">Dog</a>
        <a href="{{ routes.collections_url }}/accessories">Home</a>
        <a href="/pages/about-us">About</a>
        <a href="/pages/contact">Contact</a>
      {%- endfor -%}
    </nav>

    <div class="header-actions">
      <button class="icon-btn" aria-label="Search" id="ic-search"></button>
      <a href="{{ routes.account_url }}" class="icon-btn" aria-label="Account" id="ic-user"></a>
      <button class="icon-btn cart-btn" data-open-cart aria-label="Cart ({{ cart.item_count }} items)">
        <span id="ic-cart"></span>
        <span class="cart-count{% if cart.item_count > 0 %} show{% endif %}" data-cart-count>{{ cart.item_count }}</span>
      </button>
      <button class="icon-btn burger" aria-label="Menu" id="ic-menu"></button>
    </div>
  </div>
</header>

<nav id="mobile-nav" aria-label="Mobile">
  {%- for link in linklists[section.settings.menu].links -%}
    {%- if link.links.size > 0 -%}
      <div class="mnav-item" data-mnav-item>
        <div class="mnav-row">
          <a href="{{ link.url }}">{{ link.title }}</a>
          <button type="button" class="mnav-toggle" aria-expanded="false" aria-label="Toggle {{ link.title }} submenu"></button>
        </div>
        <div class="mnav-sub">
          {%- for child in link.links -%}
            {%- if child.links.size > 0 -%}
              <div class="mnav-subitem" data-mnav-item>
                <div class="mnav-row">
                  <a href="{{ child.url }}">{{ child.title }}</a>
                  <button type="button" class="mnav-toggle" aria-expanded="false" aria-label="Toggle {{ child.title }} submenu"></button>
                </div>
                <div class="mnav-sub">
                  {%- for grandchild in child.links -%}
                    <a href="{{ grandchild.url }}">{{ grandchild.title }}</a>
                  {%- endfor -%}
                </div>
              </div>
            {%- else -%}
              <a href="{{ child.url }}">{{ child.title }}</a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    {%- else -%}
      <a href="{{ link.url }}">{{ link.title }}</a>
    {%- endif -%}
  {%- else -%}
    <a href="{{ routes.collections_url }}/all">Products</a>
    <a href="{{ routes.collections_url }}/cat-litter">Cat Litter</a>
    <a href="{{ routes.collections_url }}/food-treats">Food &amp; Treats</a>
    <a href="{{ routes.collections_url }}/dog">Dog</a>
    <a href="{{ routes.collections_url }}/accessories">Home</a>
    <a href="/pages/about-us">About</a>
    <a href="/pages/contact">Contact</a>
  {%- endfor -%}
</nav>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo",
      "info": "Leave blank to use the default Biscuit wordmark. Recommended height: 38px."
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu",
      "info": "Create a navigation menu in your Shopify admin under Online Store → Navigation."
    }
  ]
}
{% endschema %}
