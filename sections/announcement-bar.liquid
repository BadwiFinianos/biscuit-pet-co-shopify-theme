<div class="topbar">
  <div class="topbar-inner">
    <span class="topbar-text">
      {%- if section.settings.link != blank -%}
        <a href="{{ section.settings.link }}" style="color:inherit">{{ section.settings.text }}</a>
      {%- else -%}
        {{ section.settings.text }}
      {%- endif -%}
    </span>
    {%- render 'locale-selectors', section_id: section.id -%}
  </div>
</div>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Announcement text",
      "default": "Crafted for pets with standards"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link (optional)"
    }
  ]
}
{% endschema %}
