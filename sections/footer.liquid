<footer class="site-footer">

  <!-- Newsletter CTA -->
  <div class="foot-cta">
    <span class="eyebrow on-dark">{{ section.settings.cta_eyebrow }}</span>
    <h2 style="margin-top:14px">{{ section.settings.cta_heading }}</h2>
    <p class="lead">{{ section.settings.cta_subtext }}</p>
    <form class="newsletter" id="footer-newsletter">
      <input type="email" placeholder="{{ section.settings.email_placeholder }}" required aria-label="Email address">
      <button class="btn btn--gold" type="submit">{{ section.settings.subscribe_text }}</button>
    </form>
  </div>

  <!-- Main footer columns -->
  <div class="foot-main">
    <div class="foot-brand">
      {%- if section.settings.footer_logo != blank -%}
        {{ section.settings.footer_logo | image_url: height: 80 | image_tag: style: 'height:40px;width:auto;margin-bottom:20px', alt: shop.name }}
      {%- else -%}
        <img src="{{ 'wordmark-cream.png' | asset_url }}" alt="{{ shop.name }}" style="height:40px;width:auto;margin-bottom:20px">
      {%- endif -%}
      <p>{{ section.settings.brand_blurb }}</p>
      <img class="foot-seal" src="{{ 'seal.png' | asset_url }}" alt="Biscuit Approved seal">
    </div>

    {%- for block in section.blocks -%}
      {%- if block.type == 'nav_column' -%}
        <div class="foot-col" {{ block.shopify_attributes }}>
          <h4>{{ block.settings.heading }}</h4>
          {%- if linklists[block.settings.menu] != blank -%}
            {%- for link in linklists[block.settings.menu].links -%}
              <a href="{{ link.url }}">{{ link.title }}</a>
            {%- endfor -%}
          {%- else -%}
            {{ block.settings.links }}
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- else -%}
      <!-- Default nav columns (shown until blocks are configured) -->
      <div class="foot-col">
        <h4>Shop</h4>
        <a href="{{ routes.collections_url }}/cat-litter">Cat Litter</a>
        <a href="{{ routes.collections_url }}/food-treats">Food &amp; Treats</a>
        <a href="{{ routes.collections_url }}/dog">Dog</a>
        <a href="{{ routes.collections_url }}/accessories">Home &amp; Accessories</a>
        <a href="{{ routes.collections_url }}/all">All Products</a>
      </div>
      <div class="foot-col">
        <h4>Company</h4>
        <a href="/pages/about-us">About Us</a>
        <a href="#">Biscuit Approved</a>
        <a href="#">Sustainability</a>
        <a href="#">Stockists</a>
        <a href="/pages/contact">Contact</a>
      </div>
      <div class="foot-col">
        <h4>Care</h4>
        <a href="#">Shipping &amp; Returns</a>
        <a href="#">Subscribe &amp; Save</a>
        <a href="#">FAQ</a>
        <a href="#">Track Order</a>
      </div>
    {%- endfor -%}
  </div>

  <div class="foot-bottom">
    <span>{{ section.settings.copyright }}</span>
    <span class="pays">
      {%- for method in shop.enabled_payment_types -%}
        <span>{{ method | payment_type_svg_tag: style: 'height:20px;width:auto;opacity:.7' }}</span>
      {%- else -%}
        <span>VISA</span><span>AMEX</span><span>PAYPAL</span><span>APPLE PAY</span>
      {%- endfor -%}
    </span>
  </div>

</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "header",
      "content": "Newsletter CTA"
    },
    {
      "type": "text",
      "id": "cta_eyebrow",
      "label": "Eyebrow",
      "default": "Join the household"
    },
    {
      "type": "text",
      "id": "cta_heading",
      "label": "Heading",
      "default": "Become Biscuit Approved."
    },
    {
      "type": "text",
      "id": "cta_subtext",
      "label": "Subtext",
      "default": "Early access to new scents, restock alerts, and 10% off your first order."
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email placeholder",
      "default": "you@email.com"
    },
    {
      "type": "text",
      "id": "subscribe_text",
      "label": "Subscribe button text",
      "default": "Subscribe"
    },
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "image_picker",
      "id": "footer_logo",
      "label": "Footer logo",
      "info": "Leave blank to use the default cream wordmark."
    },
    {
      "type": "textarea",
      "id": "brand_blurb",
      "label": "Brand blurb",
      "default": "Ultra-premium pet care, crafted in considered detail and held to one standard — Biscuit Approved."
    },
    {
      "type": "header",
      "content": "Bottom bar"
    },
    {
      "type": "text",
      "id": "copyright",
      "label": "Copyright text",
      "default": "© 2026 Biscuit Pet Co. · For pets with standards."
    }
  ],
  "blocks": [
    {
      "type": "nav_column",
      "name": "Navigation column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Column heading",
          "default": "Shop"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "info": "Optional — link to a navigation menu."
        }
      ]
    }
  ]
}
{% endschema %}
