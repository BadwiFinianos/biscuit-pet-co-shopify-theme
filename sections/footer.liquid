<footer class="site-footer">

  <!-- Newsletter CTA -->
  <div class="foot-cta">
    <span class="eyebrow on-dark">{{ section.settings.cta_eyebrow }}</span>
    <h2 style="margin-top:14px">{{ section.settings.cta_heading }}</h2>
    <p class="lead">{{ section.settings.cta_subtext }}</p>
    <form class="newsletter" id="footer-newsletter">
      <input type="email" placeholder="{{ section.settings.email_placeholder }}" required aria-label="{{ 'layout.footer.email_address_label' | t }}">
      <button class="btn btn--gold" type="submit">{{ section.settings.subscribe_text }}</button>
    </form>
  </div>

  <!-- Main footer columns -->
  <div class="foot-main">
    <div class="foot-brand">
      {%- if section.settings.footer_logo != blank -%}
        {{ section.settings.footer_logo | image_url: height: 140 | image_tag: style: 'height:64px;width:auto;margin-bottom:20px', alt: shop.name }}
      {%- else -%}
        <img src="{{ 'wordmark-cream.png' | asset_url }}" alt="{{ shop.name }}" style="height:64px;width:auto;margin-bottom:20px">
      {%- endif -%}
      <p>{{ section.settings.brand_blurb }}</p>
      <img class="foot-seal" src="{{ 'seal.png' | asset_url }}" alt="Biscuit Approved seal">
    </div>

    <div class="foot-col">
      <h4>{{ section.settings.menu_heading }}</h4>
      {%- if linklists[section.settings.footer_menu] != blank -%}
        {%- for link in linklists[section.settings.footer_menu].links -%}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {%- endfor -%}
      {%- endif -%}
    </div>

    <div class="foot-col foot-connect">
      <h4>{{ section.settings.connect_heading }}</h4>
      {%- render 'social-icons' -%}
      {%- if section.settings.phone_number != blank -%}
        <a class="foot-phone" href="tel:{{ section.settings.phone_number | remove: ' ' }}">{{ section.settings.phone_number }}</a>
      {%- endif -%}
    </div>
  </div>

  <div class="foot-bottom">
    <span>{{ section.settings.copyright }}</span>
    {%- render 'locale-selectors', section_id: section.id -%}
    <span class="pays">
      {%- for method in shop.enabled_payment_types -%}
        <span>{{ method | payment_type_svg_tag: style: 'height:20px;width:auto;opacity:.7' }}</span>
      {%- else -%}
        <span>VISA</span><span>AMEX</span><span>PAYPAL</span><span>APPLE PAY</span>
      {%- endfor -%}
    </span>
  </div>

</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "header",
      "content": "Newsletter CTA"
    },
    {
      "type": "text",
      "id": "cta_eyebrow",
      "label": "Eyebrow",
      "default": "Join the household"
    },
    {
      "type": "text",
      "id": "cta_heading",
      "label": "Heading",
      "default": "Become Biscuit Approved."
    },
    {
      "type": "text",
      "id": "cta_subtext",
      "label": "Subtext",
      "default": "Early access to new scents, restock alerts, and 10% off your first order."
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email placeholder",
      "default": "you@email.com"
    },
    {
      "type": "text",
      "id": "subscribe_text",
      "label": "Subscribe button text",
      "default": "Subscribe"
    },
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "image_picker",
      "id": "footer_logo",
      "label": "Footer logo",
      "info": "Leave blank to use the default cream wordmark."
    },
    {
      "type": "textarea",
      "id": "brand_blurb",
      "label": "Brand blurb",
      "default": "Ultra-premium pet care, crafted in considered detail and held to one standard — Biscuit Approved."
    },
    {
      "type": "header",
      "content": "Menu column"
    },
    {
      "type": "text",
      "id": "menu_heading",
      "label": "Menu heading",
      "default": "Shop"
    },
    {
      "type": "link_list",
      "id": "footer_menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "header",
      "content": "Connect column"
    },
    {
      "type": "text",
      "id": "connect_heading",
      "label": "Connect heading",
      "default": "Connect"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone number",
      "info": "Leave blank to hide. Social icons are managed in Theme settings → Social media."
    },
    {
      "type": "header",
      "content": "Bottom bar"
    },
    {
      "type": "text",
      "id": "copyright",
      "label": "Copyright text",
      "default": "© 2026 Biscuit Pet Co. · For pets with standards."
    }
  ]
}
{% endschema %}
