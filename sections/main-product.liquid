<section class="section wrap">
  <div class="feature inner" style="padding-block:0">

    <!-- Product media -->
    <div class="visual" data-reveal>
      {%- if product.featured_image -%}
        {{ product.featured_image | image_url: width: 900 | image_tag: class: 'shot', alt: product.title }}
      {%- else -%}
        <img class="shot" src="{{ 'litter-vanilla-cutout.png' | asset_url }}" alt="{{ product.title }}">
      {%- endif -%}
    </div>

    <!-- Product info -->
    <div data-reveal data-delay="1">
      {%- if product.type != blank -%}
        <span class="eyebrow">{{ product.type }} · {{ product.vendor }}</span>
      {%- endif -%}
      <h1 style="font-size:clamp(28px,3.8vw,46px);margin:14px 0 0;letter-spacing:-.02em">{{ product.title }}</h1>

      {%- assign current_variant = product.selected_or_first_available_variant -%}

      <div class="price" style="margin-top:18px">
        <span class="now" id="product-price">{{ current_variant.price | money }}</span>
        {%- if current_variant.compare_at_price > current_variant.price -%}
          <span class="was">{{ current_variant.compare_at_price | money }}</span>
          {%- assign savings = current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price -%}
          <span class="save">Save {{ savings }}%</span>
        {%- endif -%}
      </div>

      {%- if product.description != blank -%}
        <div class="desc" style="margin-top:18px;color:var(--ink-70);font-size:16px;line-height:1.7;max-width:48ch">
          {{ product.description }}
        </div>
      {%- endif -%}

      {%- if product.variants.size > 1 -%}
        <div class="vlabel">Choose your size</div>
        <div class="size-pills">
          {%- for variant in product.variants -%}
            <button class="size-pill{% if variant == current_variant %} on{% endif %}"
              data-variant-id="{{ variant.id }}"
              data-price="{{ variant.price }}"
              {%- unless variant.available -%} disabled{%- endunless -%}>
              {{ variant.title }}
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}

      <div class="buy" style="margin-top:28px;display:flex;gap:14px;flex-wrap:wrap">
        {%- if current_variant.available -%}
          <button class="btn btn--lg bpc-atc" data-variant-id="{{ current_variant.id }}">
            Add to Cart · {{ current_variant.price | money }}
          </button>
        {%- else -%}
          <button class="btn btn--lg" disabled style="opacity:.5;cursor:not-allowed">Sold Out</button>
        {%- endif -%}
        <a href="{{ routes.collections_url }}/all" class="btn btn--ghost btn--lg">Continue Shopping</a>
      </div>

      <!-- Trust badges -->
      <div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:24px">
        {%- if section.settings.trust_badge_1 != blank -%}
          <span style="font-size:12px;color:var(--ink-70);background:var(--card);border:1px solid var(--line-soft);border-radius:30px;padding:8px 14px">✓ {{ section.settings.trust_badge_1 }}</span>
        {%- endif -%}
        {%- if section.settings.trust_badge_2 != blank -%}
          <span style="font-size:12px;color:var(--ink-70);background:var(--card);border:1px solid var(--line-soft);border-radius:30px;padding:8px 14px">✓ {{ section.settings.trust_badge_2 }}</span>
        {%- endif -%}
        {%- if section.settings.trust_badge_3 != blank -%}
          <span style="font-size:12px;color:var(--ink-70);background:var(--card);border:1px solid var(--line-soft);border-radius:30px;padding:8px 14px">✓ {{ section.settings.trust_badge_3 }}</span>
        {%- endif -%}
      </div>
    </div>

  </div>
</section>

<script>
/* Variant switcher for product page */
document.addEventListener('DOMContentLoaded', function() {
  var pills = document.querySelectorAll('.size-pill');
  var priceEl = document.getElementById('product-price');
  var atcBtn = document.querySelector('.bpc-atc');
  pills.forEach(function(btn) {
    btn.addEventListener('click', function() {
      pills.forEach(function(x) { x.classList.remove('on'); });
      btn.classList.add('on');
      if (atcBtn && btn.dataset.variantId) {
        atcBtn.dataset.variantId = btn.dataset.variantId;
        if (btn.dataset.price && priceEl) {
          var cents = parseInt(btn.dataset.price, 10);
          var dollars = cents / 100;
          var formatted = '$' + (dollars % 1 === 0 ? dollars.toFixed(0) : dollars.toFixed(2));
          priceEl.textContent = formatted;
          atcBtn.textContent = 'Add to Cart · ' + formatted;
        }
      }
    });
  });
});
</script>

{% schema %}
{
  "name": "Product",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "trust_badge_1",
      "label": "Trust badge 1",
      "default": "Free shipping over $60"
    },
    {
      "type": "text",
      "id": "trust_badge_2",
      "label": "Trust badge 2",
      "default": "Easy returns"
    },
    {
      "type": "text",
      "id": "trust_badge_3",
      "label": "Trust badge 3",
      "default": "Biscuit Approved quality"
    }
  ]
}
{% endschema %}
