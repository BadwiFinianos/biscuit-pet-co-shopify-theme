<section class="section wrap">
  <div class="page-content" data-reveal>
    {{ page.content }}
  </div>
</section>

<style>
.page-content{max-width:760px;margin:0 auto;color:var(--ink-70);font-size:17px;line-height:1.8}
.page-content h2,.page-content h3{font-family:var(--display);color:var(--ink);letter-spacing:-.01em;margin-top:2em}
.page-content p{margin-top:1.2em}
.page-content a{color:var(--gold-deep);text-decoration:underline;text-underline-offset:3px}
.page-content ul,.page-content ol{margin-top:1.2em;padding-left:1.4em}
.page-content li{margin-top:.5em}
.page-content li::marker{color:var(--gold-deep)}
.page-content img{border-radius:var(--radius);margin-top:1.6em}
.page-content > *:first-child{margin-top:0}
</style>

{% schema %}
{
  "name": "Page content",
  "tag": "div"
}
{% endschema %}
