<section class="reviews section">
  <div class="wrap">
    <div class="reviews-head" data-reveal>
      <div class="section-head">
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        <h2 class="section-title" style="margin-top:14px">{{ section.settings.heading }}</h2>
      </div>
      <div class="score">
        <span class="big foil-text">{{ section.settings.average_rating }}</span>
        <div>
          <span class="stars">
            {%- for i in (1..5) -%}{%- render 'icon', icon: 'star' -%}{%- endfor -%}
          </span>
          <div class="sub">{{ section.settings.verified_label }}</div>
        </div>
      </div>
    </div>
    <!-- Swap this grid for a review app embed (e.g. Judge.me, Loox) in production -->
    <div class="grid grid-3">
      {%- for block in section.blocks -%}
        <div class="review" data-reveal data-delay="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
          <span class="stars">
            {%- for i in (1..5) -%}{%- render 'icon', icon: 'star' -%}{%- endfor -%}
          </span>
          <p class="review-q">&ldquo;{{ block.settings.quote }}&rdquo;</p>
          <div class="review-by">
            <div class="review-av">{{ block.settings.name | slice: 0, 1 }}</div>
            <div>
              <div class="nm">{{ block.settings.name }}</div>
              <div class="vf">{%- render 'icon', icon: 'check' -%}Verified · {{ block.settings.source }}</div>
            </div>
          </div>
        </div>
      {%- else -%}
        <!-- Default reviews (shown until blocks are configured) -->
        <div class="review" data-reveal data-delay="0">
          <span class="stars">{%- for i in (1..5) -%}{%- render 'icon', icon: 'star' -%}{%- endfor -%}</span>
          <p class="review-q">&ldquo;My flat has never smelled better. Guests genuinely cannot tell I have two cats.&rdquo;</p>
          <div class="review-by">
            <div class="review-av">A</div>
            <div><div class="nm">Amelia R.</div><div class="vf">{%- render 'icon', icon: 'check' -%}Verified · Vanilla Bean Litter</div></div>
          </div>
        </div>
        <div class="review" data-reveal data-delay="1">
          <span class="stars">{%- for i in (1..5) -%}{%- render 'icon', icon: 'star' -%}{%- endfor -%}</span>
          <p class="review-q">&ldquo;The dust-free claim is real — no more grey film on the floor by the box. Worth every penny.&rdquo;</p>
          <div class="review-by">
            <div class="review-av">D</div>
            <div><div class="nm">Daniel K.</div><div class="vf">{%- render 'icon', icon: 'check' -%}Verified · Charcoal Pure Litter</div></div>
          </div>
        </div>
        <div class="review" data-reveal data-delay="2">
          <span class="stars">{%- for i in (1..5) -%}{%- render 'icon', icon: 'star' -%}{%- endfor -%}</span>
          <p class="review-q">&ldquo;Packaging so beautiful I leave it on the shelf. The litter itself clumps like a dream.&rdquo;</p>
          <div class="review-by">
            <div class="review-av">S</div>
            <div><div class="nm">Sofia M.</div><div class="vf">{%- render 'icon', icon: 'check' -%}Verified · Lavender Calm Litter</div></div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
.reviews{background:var(--page-2)}
.reviews .grid{margin-top:48px}
.reviews-head{display:flex;align-items:flex-end;justify-content:space-between;gap:24px;flex-wrap:wrap}
.score{display:flex;align-items:center;gap:16px}
.score .big{font-family:var(--display);font-size:54px;font-weight:700;line-height:1}
.score .stars svg{width:20px;height:20px}
.score .sub{font-size:13px;color:var(--ink-50)}
@media(max-width:420px){.score{flex-direction:column;align-items:flex-start;gap:8px}.score .big{font-size:40px}.reviews-head{flex-direction:column;align-items:flex-start;gap:16px}}
</style>

{% schema %}
{
  "name": "Reviews",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Loved by pet parents"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "4.9 / 5 across 3,000+ reviews"
    },
    {
      "type": "text",
      "id": "verified_label",
      "label": "Verified label",
      "default": "Verified Biscuit customers"
    },
    {
      "type": "text",
      "id": "average_rating",
      "label": "Average rating",
      "default": "4.9"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Review text",
          "default": "My flat has never smelled better. Guests genuinely cannot tell I have two cats."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Customer name",
          "default": "Amelia R."
        },
        {
          "type": "text",
          "id": "source",
          "label": "Product purchased",
          "default": "Vanilla Bean Litter"
        }
      ]
    }
  ],
  "presets": [{ "name": "Reviews" }]
}
{% endschema %}
