<section class="section wrap">
  <div class="section-head" style="margin-bottom:48px" data-reveal>
    <span class="eyebrow">{{ collection.title }}</span>
    <h1 class="section-title" style="margin-top:14px">{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <p class="section-sub">{{ collection.description }}</p>
    {%- endif -%}
  </div>

  {%- if collection.products_count == 0 -%}
    <p style="text-align:center;padding:60px 0;color:var(--ink-50)">{{ 'collections.general.no_matches' | t }}</p>
  {%- else -%}
    <div class="grid grid-4">
      {%- for product in collection.products -%}
        {%- render 'product-card', product: product -%}
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <div style="display:flex;justify-content:center;gap:10px;margin-top:56px">
        {{- paginate | default_pagination -}}
      </div>
    {%- endif -%}
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Collection",
  "tag": "div"
}
{% endschema %}
