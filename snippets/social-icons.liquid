{%- comment -%}
  Renders icons for the social links set in Shopify admin under
  Settings → Brand → Social links. Usage: {% render 'social-icons' %}
{%- endcomment -%}
<div class="social-icons">
  {%- for link in shop.brand.social_links -%}
    {%- assign url_lower = link | downcase -%}
    {%- case true -%}
      {%- when url_lower contains 'facebook.com' -%}
        <a href="{{ link }}" class="social-icon" aria-label="Facebook" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M13.5 9H16V6h-2.5C11.6 6 10 7.6 10 9.9V12H8v3h2v6h3v-6h2.4l.6-3H13v-1.6c0-.8.2-1.4 1.5-1.4Z"/></svg>
        </a>
      {%- when url_lower contains 'instagram.com' -%}
        <a href="{{ link }}" class="social-icon" aria-label="Instagram" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3.5" y="3.5" width="17" height="17" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.2" cy="6.8" r="1" fill="currentColor" stroke="none"/></svg>
        </a>
      {%- when url_lower contains 'tiktok.com' -%}
        <a href="{{ link }}" class="social-icon" aria-label="TikTok" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M16.5 3c.4 2.2 2 3.8 4.2 4.1v3.1c-1.5 0-2.9-.4-4.2-1.3v6.5c0 3.5-2.8 6.3-6.3 6.3S4 18.9 4 15.4s2.8-6.3 6.3-6.3c.4 0 .7 0 1 .1v3.2c-.3-.1-.7-.2-1-.2-1.8 0-3.2 1.4-3.2 3.2s1.4 3.2 3.2 3.2 3.3-1.4 3.3-3.2V3h2.9Z"/></svg>
        </a>
      {%- when url_lower contains 'twitter.com' or url_lower contains 'x.com' -%}
        <a href="{{ link }}" class="social-icon" aria-label="Twitter / X" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="m4 4 7.2 9.4L4.4 20H7l5-5.4 3.9 5.4H20l-7.5-9.9L19.6 4H17l-4.6 5-3.6-5H4Z"/></svg>
        </a>
      {%- when url_lower contains 'youtube.com' or url_lower contains 'youtu.be' -%}
        <a href="{{ link }}" class="social-icon" aria-label="YouTube" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="6" width="18" height="12" rx="3.5"/><path d="m10.5 9.8 5 2.2-5 2.2Z" fill="currentColor" stroke="none"/></svg>
        </a>
      {%- when url_lower contains 'pinterest.com' -%}
        <a href="{{ link }}" class="social-icon" aria-label="Pinterest" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="9"/><path d="M9.5 20c.6-2.2 1.6-6 2-8m-.7 3.3a2.7 2.7 0 1 0 3-4.3c-1.8-.7-3.9.4-4.2 2.4"/></svg>
        </a>
    {%- endcase -%}
  {%- endfor -%}
</div>
