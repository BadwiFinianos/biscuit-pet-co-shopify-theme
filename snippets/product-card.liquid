{%- comment -%}
  Usage: {%- render 'product-card', product: product -%}
{%- endcomment -%}
<article class="pcard" data-cat="{{ product.type | handleize }}">
  <div class="pcard-media">
    {%- if product.metafields.custom.tag != blank -%}
      <span class="tag">{{ product.metafields.custom.tag }}</span>
    {%- elsif product.tags contains 'bestseller' -%}
      <span class="tag">Bestseller</span>
    {%- elsif product.tags contains 'new' -%}
      <span class="tag">New</span>
    {%- elsif product.available == false -%}
      <span class="tag sold">Sold out</span>
    {%- endif -%}

    {%- if product.featured_image -%}
      {{ product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: product.title }}
    {%- else -%}
      <img src="{{ 'litter-vanilla-cutout.png' | asset_url }}" alt="{{ product.title }}" loading="lazy">
    {%- endif -%}

    <div class="pcard-quick">
      {%- assign first_variant = product.first_available_variant | default: product.variants.first -%}
      <button class="btn btn--block" data-variant-id="{{ first_variant.id }}">
        Add to Cart · {{ first_variant.price | money }}
      </button>
    </div>
  </div>
  <div class="pcard-body">
    <div class="pcard-scent">{{ product.vendor }}</div>
    <h3 class="pcard-name"><a href="{{ product.url }}">{{ product.title }}</a></h3>
    <div class="pcard-meta">
      <span class="pcard-price">
        {%- assign fv = product.first_available_variant | default: product.variants.first -%}
        {%- if fv.compare_at_price > fv.price -%}
          <span class="was">{{ fv.compare_at_price | money }}</span>
        {%- endif -%}
        {{ fv.price | money }}
      </span>
      <span class="pcard-rating">
        <span class="stars" style="--r:4.9">
          {%- for i in (1..5) -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 3l2.6 5.7 6.1.7-4.5 4.2 1.2 6L12 17.8 6.6 19.6l1.2-6L3.3 9.4l6.1-.7L12 3Z" fill="currentColor" stroke="none"/>
            </svg>
          {%- endfor -%}
        </span>
        <span>4.9</span>
      </span>
    </div>
  </div>
</article>
