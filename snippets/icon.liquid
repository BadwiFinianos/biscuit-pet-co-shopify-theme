{%- comment -%}
  Usage: {% render 'icon', icon: 'dust' %}  or  {% render 'icon', icon: 'dust', class: 'my-class' %}
  Mirrors the ICONS set in assets/biscuit.js so icons render identically with or without JS.
{%- endcomment -%}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"{% if class %} class="{{ class }}"{% endif %}>
  {%- case icon -%}
    {%- when 'clump' -%}
      <path d="M5 19c0-4 3-5 3-9a4 4 0 0 1 8 0c0 4 3 5 3 9"/><circle cx="9" cy="9" r="1"/><circle cx="15" cy="9" r="1"/>
    {%- when 'dust' -%}
      <path d="M12 3C9 8 6 10 6 14a6 6 0 0 0 12 0c0-4-3-6-6-11Z"/><path d="M12 16a2.5 2.5 0 0 0 2.5-2.5"/>
    {%- when 'absorb' -%}
      <path d="M12 3s6 6 6 11a6 6 0 1 1-12 0c0-5 6-11 6-11Z"/>
    {%- when 'odor' -%}
      <path d="M4 18c4 0 4-3 8-3s4 3 8 3"/><path d="M6 13c0-3 2-5 6-5s6 2 6 5"/><path d="M9 8c.5-2 1.5-3 3-3s2.5 1 3 3"/>
    {%- when 'mineral' -%}
      <path d="M12 3 4 8v8l8 5 8-5V8l-8-5Z"/><path d="M12 3v18M4 8l8 5 8-5"/>
    {%- when 'leaf' -%}
      <path d="M5 19c0-8 6-14 14-14 0 8-6 14-14 14Z"/><path d="M5 19c3-5 6-8 11-10"/>
    {%- when 'shield' -%}
      <path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3Z"/><path d="m9 12 2 2 4-4"/>
    {%- when 'sparkle' -%}
      <path d="M12 3v6M12 15v6M3 12h6M15 12h6" opacity=".5"/><path d="M12 7c.6 2.6 2.4 4.4 5 5-2.6.6-4.4 2.4-5 5-.6-2.6-2.4-4.4-5-5 2.6-.6 4.4-2.4 5-5Z"/>
    {%- when 'check' -%}
      <path d="m4 12 5 5L20 6"/>
    {%- when 'star' -%}
      <path d="M12 3l2.6 5.7 6.1.7-4.5 4.2 1.2 6L12 17.8 6.6 19.6l1.2-6L3.3 9.4l6.1-.7L12 3Z" fill="currentColor" stroke="none"/>
    {%- when 'arrow' -%}
      <path d="M4 12h15m-6-6 6 6-6 6"/>
  {%- endcase -%}
</svg>
