<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">

  <title>
    {%- if template.name == 'index' -%}{{ shop.name }} — Premium Pet Lifestyle
    {%- elsif page_title contains shop.name -%}{{ page_title }}
    {%- else -%}{{ page_title }} — {{ shop.name }}
    {%- endif -%}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}
  <link rel="canonical" href="{{ canonical_url }}">

  {{ content_for_header }}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,500;1,600&family=Montserrat:wght@300;400;500;600;700&display=swap">
  {{ 'biscuit.css' | asset_url | stylesheet_tag }}
</head>
<body class="template-{{ template.name }}">

  {% section 'announcement-bar' %}
  {% section 'header' %}

  <main id="main-content" role="main">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  <!-- Cart drawer + toast (built by biscuit.js) -->
  <div id="bpc-toast" class="toast"></div>

  <script>
    window.bpcData = {
      cart: {{ cart | json }},
      routes: {
        cart_add:    '{{ routes.cart_add_url }}',
        cart:        '{{ routes.cart_url }}',
        cart_change: '{{ routes.cart_change_url }}'
      },
      assets: {
        mascotNavy:   '{{ "mascot-navy.png"    | asset_url }}',
        mascotGold:   '{{ "mascot-gold.png"    | asset_url }}',
        monoGold:     '{{ "monogram-gold.png"  | asset_url }}',
        monoNavy:     '{{ "monogram-navy.png"  | asset_url }}',
        wordmarkCream:'{{ "wordmark-cream.png" | asset_url }}',
        wordmarkNavy: '{{ "wordmark-navy.png"  | asset_url }}',
        seal:         '{{ "seal.png"           | asset_url }}',
        packshot:     '{{ "litter-vanilla-cutout.png" | asset_url }}'
      }
    };
  </script>
  {{ 'biscuit.js' | asset_url | script_tag }}

</body>
</html>
