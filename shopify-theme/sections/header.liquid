<header class="site-header">
  <div class="header-row">
    <a class="brand" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        {{ section.settings.logo | image_url: height: 76 | image_tag: class: '', alt: shop.name }}
      {%- else -%}
        <img src="{{ 'wordmark-navy.png' | asset_url }}" alt="{{ shop.name }}" style="height:76px;width:auto" width="auto" height="76px">
      {%- endif -%}
    </a>

    <nav class="nav" aria-label="Primary">
      {%- for link in linklists[section.settings.menu].links -%}
        <a href="{{ link.url }}"{% if link.active %} class="active"{% endif %}>{{ link.title }}</a>
      {%- else -%}
        <a href="{{ routes.collections_url }}/all">Shop All</a>
        <a href="{{ routes.collections_url }}/cat-litter">Cat Litter</a>
        <a href="{{ routes.collections_url }}/food-treats">Food &amp; Treats</a>
        <a href="{{ routes.collections_url }}/dog">Dog</a>
        <a href="{{ routes.collections_url }}/accessories">Home</a>
        <a href="/pages/about-us">About</a>
        <a href="/pages/contact">Contact</a>
      {%- endfor -%}
    </nav>

    <div class="header-actions">
      <button class="icon-btn" aria-label="Search" id="ic-search"></button>
      <a href="{{ routes.account_url }}" class="icon-btn" aria-label="Account" id="ic-user"></a>
      <button class="icon-btn cart-btn" data-open-cart aria-label="Cart ({{ cart.item_count }} items)">
        <span id="ic-cart"></span>
        <span class="cart-count{% if cart.item_count > 0 %} show{% endif %}" data-cart-count>{{ cart.item_count }}</span>
      </button>
      <button class="icon-btn burger" aria-label="Menu" id="ic-menu"></button>
    </div>
  </div>
</header>

<nav id="mobile-nav" aria-label="Mobile">
  {%- for link in linklists[section.settings.menu].links -%}
    <a href="{{ link.url }}">{{ link.title }}</a>
  {%- else -%}
    <a href="{{ routes.collections_url }}/all">Shop All</a>
    <a href="{{ routes.collections_url }}/cat-litter">Cat Litter</a>
    <a href="{{ routes.collections_url }}/food-treats">Food &amp; Treats</a>
    <a href="{{ routes.collections_url }}/dog">Dog</a>
    <a href="{{ routes.collections_url }}/accessories">Home</a>
    <a href="/pages/about-us">About</a>
    <a href="/pages/contact">Contact</a>
  {%- endfor -%}
</nav>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo",
      "info": "Leave blank to use the default Biscuit wordmark. Recommended height: 38px."
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu",
      "info": "Create a navigation menu in your Shopify admin under Online Store → Navigation."
    }
  ]
}
{% endschema %}
