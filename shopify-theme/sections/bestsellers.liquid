{%- assign bs_collection = collections[section.settings.collection] -%}

<section class="section wrap">
  <div class="reviews-head" style="margin-bottom:48px" data-reveal>
    <div class="section-head">
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="section-title" style="margin-top:14px">{{ section.settings.heading }}</h2>
    </div>
    <a href="{{ bs_collection.url | default: routes.collections_url | append: '/all' }}" class="link-underline">
      View all <span id="bs-arw"></span>
    </a>
  </div>

  <div class="grid grid-4" data-reveal>
    {%- if bs_collection != blank -%}
      {%- for product in bs_collection.products limit: section.settings.products_count -%}
        {%- render 'product-card', product: product -%}
      {%- else -%}
        {%- render 'dummy-product-cards' -%}
      {%- endfor -%}
    {%- else -%}
      <!-- Dummy cards shown until a collection is selected -->
      {%- assign dummy_products = "Vanilla Bean Cat Litter,Wild Salmon Cat Cuisine,Lavender Calm Cat Litter,Cloud Bouclé Pet Bed" | split: "," -%}
      {%- assign dummy_prices   = "34,28,34,128"   | split: "," -%}
      {%- assign dummy_was      = "39,0,0,0"        | split: "," -%}
      {%- assign dummy_tags     = "Bestseller,New,New,New" | split: "," -%}
      {%- for name in dummy_products -%}
        {%- assign idx = forloop.index0 -%}
        <article class="pcard">
          <div class="pcard-media">
            {%- if dummy_tags[idx] != "" -%}
              <span class="tag">{{ dummy_tags[idx] }}</span>
            {%- endif -%}
            <img src="{{ 'litter-vanilla-cutout.png' | asset_url }}" alt="{{ name }}" loading="lazy">
            <div class="pcard-quick">
              <button class="btn btn--block">Add to Cart · ${{ dummy_prices[idx] }}</button>
            </div>
          </div>
          <div class="pcard-body">
            <div class="pcard-scent">Biscuit Pet Co.</div>
            <h3 class="pcard-name"><a href="#">{{ name }}</a></h3>
            <div class="pcard-meta">
              <span class="pcard-price">
                {%- if dummy_was[idx] != "0" -%}<span class="was">${{ dummy_was[idx] }}</span>{%- endif -%}
                ${{ dummy_prices[idx] }}
              </span>
              <span class="pcard-rating">
                <span class="stars" style="--r:4.9">
                  {%- for i in (1..5) -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l2.6 5.7 6.1.7-4.5 4.2 1.2 6L12 17.8 6.6 19.6l1.2-6L3.3 9.4l6.1-.7L12 3Z" fill="currentColor" stroke="none"/></svg>{%- endfor -%}
                </span>
                <span>4.9</span>
              </span>
            </div>
          </div>
        </article>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Bestsellers",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Most loved"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Bestsellers"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Choose a collection to pull products from. If left blank, dummy cards are shown."
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "Products to show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [{ "name": "Bestsellers" }]
}
{% endschema %}
