<section class="story section" id="story">
  <div class="wrap inner">
    <div data-reveal>
      <span class="eyebrow on-dark">{{ section.settings.eyebrow }}</span>
      <blockquote>{{ section.settings.quote_text }} <em>{{ section.settings.quote_em }}</em></blockquote>
      <p>{{ section.settings.paragraph1 }}</p>
      <p>{{ section.settings.paragraph2 }}</p>
      <div class="sig">{{ section.settings.signature }}</div>
    </div>
    <div class="mascot-lg" data-reveal data-delay="1">
      {%- if section.settings.mascot != blank -%}
        {{ section.settings.mascot | image_url: height: 520 | image_tag: alt: '' }}
      {%- else -%}
        <img src="{{ 'mascot-gold.png' | asset_url }}" alt="Biscuit cat mascot">
      {%- endif -%}
    </div>
  </div>
</section>

<style>
.story{background:linear-gradient(155deg,#000048,var(--navy) 60%,#000031);color:var(--cream);position:relative;overflow:hidden}
.story .inner{display:grid;grid-template-columns:1.1fr .9fr;gap:clamp(36px,5vw,72px);align-items:center}
.story .mascot-lg{position:relative;display:grid;place-items:center}
.story .mascot-lg::before{content:"";position:absolute;width:78%;aspect-ratio:1;border-radius:50%;background:radial-gradient(circle,rgba(212,175,55,.16),transparent 62%)}
.story .mascot-lg img{position:relative;height:min(60vh,520px);filter:drop-shadow(0 30px 40px rgba(0,0,0,.4))}
.story blockquote{font-family:var(--display);font-size:clamp(28px,3.6vw,46px);line-height:1.18;letter-spacing:-.015em;color:var(--cream);margin:18px 0 0;font-weight:500}
.story blockquote em{font-style:italic;color:var(--gold-light)}
.story p{margin-top:24px;color:rgba(242,234,211,.72);font-size:16px;line-height:1.75;max-width:46ch}
.story .sig{margin-top:26px;font-family:var(--display);font-style:italic;font-size:22px;color:var(--gold-light)}
@media(max-width:960px){
  .story .inner{grid-template-columns:1fr;text-align:center}
  .story .mascot-lg{order:-1}
  .story .mascot-lg img{height:min(50vh,400px)}
}
@media(max-width:560px){.story .mascot-lg img{height:min(42vh,300px)}}
</style>

{% schema %}
{
  "name": "Brand Story",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Our Philosophy"
    },
    {
      "type": "text",
      "id": "quote_text",
      "label": "Quote (plain text)",
      "default": "Premium pet lifestyle for pets with"
    },
    {
      "type": "text",
      "id": "quote_em",
      "label": "Quote italic ending",
      "default": "standards."
    },
    {
      "type": "textarea",
      "id": "paragraph1",
      "label": "Paragraph 1",
      "default": "Biscuit began with a simple conviction: the everyday objects of pet care — the litter, the bowl, the bed — deserve the same craft we give our own homes. So we obsess over mineral sourcing, scent balance, and foil-stamped detail, then hold every batch to one test."
    },
    {
      "type": "textarea",
      "id": "paragraph2",
      "label": "Paragraph 2",
      "default": "If it isn't Biscuit Approved, it doesn't ship."
    },
    {
      "type": "text",
      "id": "signature",
      "label": "Signature",
      "default": "— The Biscuit Atelier"
    },
    {
      "type": "image_picker",
      "id": "mascot",
      "label": "Mascot image",
      "info": "Leave blank to use the default gold mascot."
    }
  ],
  "presets": [{ "name": "Brand Story" }]
}
{% endschema %}
