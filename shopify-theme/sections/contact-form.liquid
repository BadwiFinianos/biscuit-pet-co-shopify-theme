<section class="section wrap contact-section">
  <div class="contact-grid">
    <div class="contact-info" data-reveal>
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="section-title" style="margin-top:14px">{{ section.settings.heading }}</h2>
      <p class="section-sub">{{ section.settings.description }}</p>

      <ul class="contact-details">
        {%- if section.settings.email != blank -%}
          <li>
            <span class="label">Email</span>
            <a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a>
          </li>
        {%- endif -%}
        {%- if section.settings.phone != blank -%}
          <li>
            <span class="label">Phone</span>
            <a href="tel:{{ section.settings.phone | remove: ' ' }}">{{ section.settings.phone }}</a>
          </li>
        {%- endif -%}
        {%- if section.settings.address != blank -%}
          <li>
            <span class="label">Address</span>
            <span>{{ section.settings.address }}</span>
          </li>
        {%- endif -%}
        {%- if section.settings.hours != blank -%}
          <li>
            <span class="label">Hours</span>
            <span>{{ section.settings.hours }}</span>
          </li>
        {%- endif -%}
      </ul>
    </div>

    <div class="contact-form-wrap" data-reveal data-delay="1">
      {%- form 'contact', id: 'ContactForm', class: 'contact-form' -%}
        {%- if form.posted_successfully? -%}
          <p class="form-message success">{{ section.settings.success_message }}</p>
        {%- endif -%}
        {%- if form.errors -%}
          <p class="form-message error">
            {{ form.errors.messages['base'] | default: 'Something went wrong — please check your details and try again.' }}
          </p>
        {%- endif -%}

        <div class="field">
          <label for="ContactFormName">Name</label>
          <input type="text" id="ContactFormName" name="contact[name]" value="{{ form.name }}" autocomplete="name" required>
        </div>

        <div class="field">
          <label for="ContactFormEmail">Email</label>
          <input type="email" id="ContactFormEmail" name="contact[email]" value="{{ form.email }}" autocomplete="email" required>
        </div>

        <div class="field">
          <label for="ContactFormPhone">Phone <span class="optional">(optional)</span></label>
          <input type="tel" id="ContactFormPhone" name="contact[phone]" value="{{ form.phone }}" autocomplete="tel">
        </div>

        <div class="field">
          <label for="ContactFormMessage">Message</label>
          <textarea id="ContactFormMessage" name="contact[body]" rows="6" required>{{ form.body }}</textarea>
        </div>

        <button type="submit" class="btn btn--gold btn--block">{{ section.settings.submit_text }}</button>
      {%- endform -%}
    </div>
  </div>
</section>

<style>
.contact-grid{display:grid;grid-template-columns:.85fr 1.15fr;gap:clamp(40px,6vw,80px);align-items:start}

.contact-details{margin-top:36px;display:flex;flex-direction:column;gap:20px;padding:0}
.contact-details li{display:flex;flex-direction:column;gap:4px}
.contact-details .label{font-size:11px;font-weight:600;letter-spacing:.16em;text-transform:uppercase;color:var(--gold-deep)}
.contact-details a,.contact-details span:not(.label){color:var(--ink-70);font-size:16px}
.contact-details a:hover{color:var(--navy)}

.contact-form{display:flex;flex-direction:column;gap:20px;background:var(--card);border:1px solid var(--line-soft);border-radius:6px;padding:clamp(28px,4vw,44px);box-shadow:var(--shadow-sm)}
.field{display:flex;flex-direction:column;gap:8px}
.field label{font-size:12px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-70)}
.field .optional{text-transform:none;font-weight:400;letter-spacing:0;color:var(--ink-35)}
.field input,.field textarea{
  font-family:var(--body);font-size:15px;color:var(--ink);
  background:var(--page);border:1px solid var(--line);border-radius:var(--radius);
  padding:14px 16px;resize:vertical;transition:border-color .25s;
}
.field input:focus,.field textarea:focus{outline:none;border-color:var(--gold)}
.form-message{padding:14px 16px;border-radius:var(--radius);font-size:14px}
.form-message.success{background:rgba(212,175,55,.14);color:var(--gold-deep)}
.form-message.error{background:rgba(178,32,32,.08);color:#8a1f1f}

@media(max-width:860px){.contact-grid{grid-template-columns:1fr}}
</style>

{% schema %}
{
  "name": "Contact form",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "We'd love to hear from you"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get in touch."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Questions about an order, a product, or just want to say hello? Send us a message and a member of the Biscuit team will get back to you within one business day."
    },
    {
      "type": "text",
      "id": "email",
      "label": "Contact email",
      "default": "hello@biscuitpetco.com"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone number"
    },
    {
      "type": "text",
      "id": "address",
      "label": "Address"
    },
    {
      "type": "text",
      "id": "hours",
      "label": "Hours",
      "default": "Mon–Fri, 9am–5pm"
    },
    {
      "type": "text",
      "id": "submit_text",
      "label": "Submit button text",
      "default": "Send Message"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thank you — your message has been sent. We'll be in touch soon."
    }
  ],
  "presets": [{ "name": "Contact form" }]
}
{% endschema %}
